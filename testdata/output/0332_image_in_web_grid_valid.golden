<compono-web-grid data-grid-template-columns="1fr" data-grid-template-rows="min-content 1fr" data-grid-template-areas='[["hero"],["content"]]'><compono-web-grid-item data-grid-area="hero"><picture><source type="image/webp" srcset="https://cdn.example.com/grid-hero-640.webp 640w"><img src="https://cdn.example.com/grid-hero.jpg" alt="Grid hero" width="1600" height="900"></picture></compono-web-grid-item><compono-web-grid-item data-grid-area="content"><p>Grid content.</p></compono-web-grid-item></compono-web-grid>
