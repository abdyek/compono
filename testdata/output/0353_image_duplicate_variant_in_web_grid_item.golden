<compono-web-grid data-grid-template-columns="1fr" data-grid-template-rows="1fr" data-grid-template-areas='[["hero"]]'><compono-web-grid-item data-grid-area="hero"><compono-error-block><div slot="title">Duplicate variant</div><div slot="description">The variant with mime-type <strong>image/webp</strong> and width <strong>640</strong> is defined more than once.</div></compono-error-block></compono-web-grid-item></compono-web-grid>
