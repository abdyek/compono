<compono-web-grid data-grid-template-columns="minmax(min-content,1fr)" data-grid-template-rows="max-content 1fr" data-grid-template-areas='[["hero"],["aside"]]' data-sm-grid-template-columns="1fr 2fr" data-sm-grid-template-rows="1fr" data-sm-grid-template-areas='[["hero","aside"]]' data-lg-grid-template-columns="2fr 1fr 1fr" data-lg-grid-template-rows="1fr" data-lg-grid-template-areas='[["hero","aside","aside"]]'><compono-web-grid-item data-grid-area="hero"><h1>Hero</h1></compono-web-grid-item><compono-web-grid-item data-grid-area="aside"><p>Sidebar</p></compono-web-grid-item></compono-web-grid>
