<compono-web-grid data-grid-template-columns="1fr" data-grid-template-rows="1fr" data-grid-template-areas='[["card"]]'><compono-web-grid-item data-grid-area="card"><picture><source type="image/webp" srcset="https://cdn.example.com/grid-card-640.webp 640w"><img src="https://cdn.example.com/grid-card.jpg" alt="Grid card image" width="1600" height="900"></picture></compono-web-grid-item></compono-web-grid>
