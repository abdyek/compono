{{ IMAGE_WRAPPER media = {
  url: "https://cdn.example.com/wrapped.jpg",
  width: 1600,
  height: 900,
  mime-type: "image/jpeg",
  variants: [
    {
      url: "https://cdn.example.com/wrapped-640.webp",
      width: 640,
      height: 360,
      mime-type: "image/webp"
    },
    {
      url: "https://cdn.example.com/wrapped-1280.webp",
      width: 1280,
      height: 720,
      mime-type: "image/webp"
    }
  ]
} alt = "Wrapped image" }}

~ IMAGE_WRAPPER media = {} alt = ""
{{ IMAGE media = media alt = alt }}
